# Datadog Agent
DD_API_KEY=replace-me
DD_SITE=datadoghq.com
DD_ENV=local
DD_VERSION=0.1.0

# Postgres
POSTGRES_USER=voting
POSTGRES_PASSWORD=voting
POSTGRES_DB=voting

# Datadog Postgres integration
# Created on first postgres init (fresh pgdata volume) via
# scripts/postgres-init/datadog.sh. Demo creds — not for real deployments.
DD_POSTGRES_USER=datadog
DD_POSTGRES_PASSWORD=password123

# Worker
TALLY_INTERVAL=5s
